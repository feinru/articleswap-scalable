HOST=0.0.0.0
PORT=3000
DATABASE_URL=postgresql://articleswap:articleswap@postgres:5432/articleswap
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=article-submissions
KAFKA_CLIENT_ID=article-service

# IP rate limit for POST /api/articles.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
# Set to number of trusted proxies in front of service, e.g. 1 behind nginx.
TRUST_PROXY=1

# Read API in-memory cache.
ARTICLE_CACHE_TTL_MS=30000
ARTICLE_CACHE_MAX_ENTRIES=500

# Kafka publish circuit breaker.
KAFKA_CIRCUIT_FAILURE_THRESHOLD=3
KAFKA_CIRCUIT_COOLDOWN_MS=10000
