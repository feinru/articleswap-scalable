# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=article-submissions
KAFKA_CLIENT_ID=articles-api-gateway
# Optional: override default per-instance group id (default: gateway-${HOSTNAME})
# KAFKA_CONSUMER_GROUP=gateway-1

# Cluster peers for cross-instance SSE broadcast (HTTP fallback).
# Comma-separated host:port list. Each gateway broadcasts to these on local sendToReceiver.
CLUSTER_PEERS=gateway1:5173,gateway2:5173
