# Image references (tag can be latest, a branch, or a SHA).
# Update these or pass via shell env when running the deploy script.
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=kevinantoniowiyonolauw
IMAGE_TAG=latest

IMAGE_API_GATEWAY=${IMAGE_REGISTRY}/${IMAGE_NAMESPACE}/articleswap-api-gateway:${IMAGE_TAG}
IMAGE_ARTICLE_SERVICE=${IMAGE_REGISTRY}/${IMAGE_NAMESPACE}/articleswap-article-service:${IMAGE_TAG}
IMAGE_STEMMING_SERVICE=${IMAGE_REGISTRY}/${IMAGE_NAMESPACE}/articleswap-stemming-service:${IMAGE_TAG}
IMAGE_WORDCLOUD_SERVICE=${IMAGE_REGISTRY}/${IMAGE_NAMESPACE}/articleswap-wordcloud-service:${IMAGE_TAG}
IMAGE_FORWARDING_INBOX_SERVICE=${IMAGE_REGISTRY}/${IMAGE_NAMESPACE}/articleswap-forwarding-inbox-service:${IMAGE_TAG}
IMAGE_NGINX=${IMAGE_REGISTRY}/${IMAGE_NAMESPACE}/articleswap-nginx:${IMAGE_TAG}

# Internal Docker DNS hostnames.
# Containers talk to each other via these service names on the
# `articleswap-net` network — no `localhost`, no host ports.
POSTGRES_HOST=postgres
RABBITMQ_HOST=rabbitmq
MINIO_HOST=minio

# Postgres
POSTGRES_USER=articleswap
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=articleswap
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:5432/${POSTGRES_DB}

# RabbitMQ
RABBITMQ_USER=articleswap
RABBITMQ_PASSWORD=rabbitmqscalable
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:5672
RABBITMQ_QUEUE=article-submissions
RABBITMQ_DELIVERED_EXCHANGE=article-delivered.exchange
RABBITMQ_PREFETCH=1

# MinIO
MINIO_ROOT_USER=articleswap
MINIO_ROOT_PASSWORD=change-me-strong
MINIO_BUCKET=wordclouds

# Public URL the browser uses to load generated wordcloud images.
# This must be reachable from the user's browser, NOT the container network.
# Examples:
#   https://minio.<your-domain>
#   https://<your-domain>/minio (when fronted by nginx)
PUBLIC_MINIO_URL=https://minio.example.com

# Public hostnames for the API gateway / article service / nginx from the
# browser. Used by api-gateway to know how to reach article-service
# (always internal) and by clients to reach the dashboard.
GATEWAY_PUBLIC_URL=https://app.example.com

# Rate limit (article-service POST /api/articles).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Exposed host ports.
NGINX_HOST_PORT=8080
RABBITMQ_MANAGEMENT_HOST_PORT=15672
